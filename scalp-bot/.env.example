# ═══════════════════════════════════════════════════════════════════════════════
# Solana Memecoin Scalp Bot — Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT: Use a dedicated BURNER WALLET with small balance only!
# Never use your main wallet. Start with DRY_RUN=true.

# ─── Core ────────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
WALLET_PRIVATE_KEY=
DRY_RUN=true

# ─── Jupiter ─────────────────────────────────────────────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=

# ─── Position Sizing ─────────────────────────────────────────────────────────
MAX_POSITION_SOL=0.02       # Max SOL per trade (start TINY)
MAX_OPEN_POSITIONS=2        # Max concurrent positions
STOP_LOSS_PCT=-15           # Hard stop-loss (sell everything at -15%)
MAX_HOLD_SEC=1800           # Force close after 30 min
MIN_SOL_RESERVE=0.05        # Keep this much SOL for gas/tips

# ─── Trailing Stop ──────────────────────────────────────────────────────────
TRAILING_ACTIVATION_PCT=25  # Activate trailing stop at +25%
TRAILING_DISTANCE_PCT=12    # Sell if price drops 12% from peak

# ─── Token Safety Filters ───────────────────────────────────────────────────
MIN_LIQUIDITY_USD=10000     # Min pool liquidity
MIN_VOLUME_USD=5000         # Min 24h volume
MAX_TOP_HOLDER_PCT=25       # Max % held by top wallet
MIN_HOLDERS=100             # Min number of holders
MIN_POOL_AGE_SEC=60         # Min pool age (avoid brand-new rugs)
MAX_POOL_AGE_SEC=86400      # Max pool age (fresh tokens only)

# ─── Signal ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=3000       # Scan every 3 seconds
MIN_ENTRY_SCORE=65          # Min score to trigger buy (0-100)

# ─── bloXroute (optional — parallel relay) ───────────────────────────────────
# BLOXROUTE_AUTH_TOKEN=
